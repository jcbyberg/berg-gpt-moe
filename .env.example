# Hive Mind Environment Configuration Template
# Copy this file to .env and fill in your actual values
# cp .env.example .env

# ============================================
# REDIS CONFIGURATION
# ============================================
# Redis connection URL for hot memory (vector search)
REDIS_URL=redis://localhost:6379

# Redis authentication password (leave empty if no password)
REDIS_PASSWORD=

# Maximum memory allocation for Redis (e.g., "4gb")
REDIS_MAX_MEMORY=4gb

# Time-to-live for hot memory entries in seconds (3600 = 1 hour)
# After TTL expires, entries are automatically removed from hot memory
REDIS_TTL=3600

# ============================================
# LANCEDB CONFIGURATION
# ============================================
# File path for cold memory storage (LanceDB)
LANCEDB_PATH=./hive_cold_memory.lance

# Number of partitions for LanceDB vector index
LANCEDB_NUM_PARTITIONS=256

# Number of sub-vectors for IVF-PQ compression
LANCEDB_NUM_SUB_VECTORS=96

# Reranker model path for LanceDB (Cross-Encoder)
LANCEDB_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ============================================
# API CONFIGURATION
# ============================================
# Orchestrator API host binding
API_HOST=0.0.0.0

# Orchestrator API port
API_PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================
# AI PROVIDER CONFIGURATION
# ============================================
# Google Gemini API key for AI responses
GOOGLE_API_KEY=

# Tavily API key for web search (Web Scout agent)
TAVILY_API_KEY=

# GitHub token for code search (Code Hunter agent)
GITHUB_TOKEN=

# ZAI API key for GLM-5 model (optional - enables ZAI provider)
ZAI_API_KEY=

# Default Gemini model for agents (gemini-2.5-flash is recommended)
GEMINI_MODEL=gemini-2.5-flash

# Model used by orchestrator for planning and synthesis
ORCHESTRATOR_MODEL=gemini-1.5-pro

# Default ZAI model for agents using GLM-5
ZAI_MODEL=glm-5

# Fallback ZAI model if the primary model fails
ZAI_FALLBACK_MODEL=glm-4.7

# ============================================
# REDDIT CONFIGURATION
# ============================================
# Reddit client ID for Social Sentiment agent
REDDIT_CLIENT_ID=

# Reddit client secret
REDDIT_CLIENT_SECRET=

# Reddit user agent string
REDDIT_USER_AGENT=python:hive-mind:v2.1.0

# ============================================
# MCP CONFIGURATION
# ============================================
# Timeout in seconds for MCP server calls
MCP_TIMEOUT=30

# Number of retry attempts for MCP server calls
MCP_RETRY_ATTEMPTS=3

# ============================================
# MEMORY CONFIGURATION
# ============================================
# Number of entries to prune from hot memory in each cleanup cycle
HOT_MEMORY_PRUNE_SIZE=1000

# Number of entries to archive from hot to cold memory per batch
COLD_MEMORY_ARCHIVE_BATCH=50'
